# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PostgreSQL settings used by docker-compose.
POSTGRES_DB="docflow"
POSTGRES_USER="docflow"
POSTGRES_PASSWORD="docflow"
POSTGRES_PORT="5432"

# Backend/API config.
VITE_API_URL="http://localhost:9000"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
API_PORT="9000"
FRONTEND_PORT="3000"
VITE_API_URL=http://127.0.0.1:9000
VITE_API_URL=http://api:8000

# Google OAuth (Gmail verification)
# Create OAuth client credentials (Web application) and set redirect URI.
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="http://localhost:9000/integrations/gmail/callback"
GOOGLE_OAUTH_STATE_SECRET="change_this_to_a_random_secret"
FRONTEND_URL="http://localhost:3000"
